{
  "name": "@webhouse/cms",
  "version": "0.2.14",
  "description": "AI-native CMS engine built on Hono, Drizzle ORM, and SQLite",
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./adapters": {
      "types": "./dist/adapters/index.d.ts",
      "import": "./dist/adapters/index.js",
      "require": "./dist/adapters/index.cjs"
    },
    "./next": {
      "types": "./dist/next/index.d.ts",
      "import": "./dist/next/index.js",
      "require": "./dist/next/index.cjs"
    },
    "./static/*": "./static/*"
  },
  "files": [
    "dist",
    "static",
    "README.md",
    "CLAUDE.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/webhousecode/cms.git",
    "directory": "packages/cms"
  },
  "homepage": "https://github.com/webhousecode/cms#readme",
  "bugs": {
    "url": "https://github.com/webhousecode/cms/issues"
  },
  "keywords": [
    "cms",
    "headless-cms",
    "ai-native",
    "content-management",
    "hono",
    "drizzle",
    "sqlite",
    "zod",
    "typescript"
  ],
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "hono": "^4.6.14",
    "@hono/node-server": "^1.13.7",
    "drizzle-orm": "^0.38.3",
    "better-sqlite3": "^11.7.0",
    "zod": "^3.24.1",
    "nanoid": "^5.0.9",
    "marked": "^15.0.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2",
    "tsup": "^8.3.5",
    "vitest": "^2.1.8"
  }
}
