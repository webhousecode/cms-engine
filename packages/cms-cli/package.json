{
  "name": "@webhouse/cms-cli",
  "version": "0.1.2",
  "description": "CLI for @webhouse/cms — init, dev, build, and AI content tools",
  "type": "module",
  "license": "MIT",
  "bin": {
    "cms": "./dist/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/webhousecode/cms.git",
    "directory": "packages/cms-cli"
  },
  "homepage": "https://github.com/webhousecode/cms#readme",
  "bugs": {
    "url": "https://github.com/webhousecode/cms/issues"
  },
  "keywords": [
    "cms",
    "cli",
    "webhouse",
    "ai-native",
    "static-site-generator",
    "content-management",
    "typescript"
  ],
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@webhouse/cms": "^0.1.1",
    "@webhouse/cms-ai": "^0.1.1",
    "@hono/node-server": "^1.13.7",
    "jiti": "^2.4.2",
    "citty": "^0.1.6",
    "chokidar": "^4.0.3",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2",
    "tsup": "^8.3.5"
  }
}
