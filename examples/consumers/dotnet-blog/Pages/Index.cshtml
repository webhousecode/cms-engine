@page
@model IndexModel
@{
    ViewData["Title"] = "Blog";
}

<h1>Blog</h1>
<p class="lead">
    Content read from @@webhouse/cms JSON files by an ASP.NET Core 9 Razor Pages app.
</p>

@if (!Model.Posts.Any())
{
    <p>No published posts yet.</p>
}
else
{
    @foreach (var post in Model.Posts)
    {
        <a class="post-card" asp-page="/Blog/Post" asp-route-slug="@post.Slug">
            <div class="meta">
                <span>@post.GetStringOr("date", "")</span>
                <span> · </span>
                <span>@post.Locale</span>
            </div>
            <h3>@post.GetString("title")</h3>
            <p>@post.GetString("excerpt")</p>
        </a>
    }
}
