---
import Layout from '../../layouts/Layout.astro';
import { cms, getString } from '../../lib/webhouse';

const posts = cms.collection('posts', 'da');
---

<Layout title="Blog (da)">
  <h1>Blog</h1>
  <p class="lead">Indhold læst fra @webhouse/cms JSON-filer af en Astro 5-app.</p>

  {posts.length === 0 && <p>Ingen publicerede indlæg endnu.</p>}

  {posts.map((post) => (
    <a href={`/blog/${post.slug}`} class="post-card">
      <div class="meta">
        <span>{getString(post, 'date')}</span>
        <span> · </span>
        <span>{post.locale}</span>
      </div>
      <h3>{getString(post, 'title')}</h3>
      <p>{getString(post, 'excerpt')}</p>
    </a>
  ))}
</Layout>
