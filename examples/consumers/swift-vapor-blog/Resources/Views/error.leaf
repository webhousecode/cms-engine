#extend("_layout"):
#export("body"):
<div style="text-align: center; padding: 4rem 0;">
  <h1 style="font-size: 5rem; color: var(--gold); font-family: 'JetBrains Mono', monospace;">#(statusCode)</h1>
  <h2 style="margin-top: 1rem;">#(statusText)</h2>
  <p style="margin-top: 2rem;"><a href="/" class="back">← Back to all posts</a></p>
</div>
#endexport
#endextend
